rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is admin (custom claim or known admin)
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    // Artworks: public read, admin-only write
    match /artworks/{artworkId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    // Inquiries: server-side create (via API), admin read/delete
    match /inquiries/{inquiryId} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'email', 'type', 'artwork', 'message', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() < 200
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.message.size() < 5000;
      allow read, update, delete: if isAdmin();
    }

    // Enhancement logs: admin only
    match /enhance_logs/{logId} {
      allow read, write: if isAdmin();
    }

    // Guestbook: submissions via server API only, admin can manage
    match /guestbook/{entryId} {
      allow read, update, delete: if isAdmin();
    }

    // Logs: admin only
    match /logs/{logId} {
      allow read, write: if isAdmin();
    }

    // Rate limits: server-side only (admin SDK bypasses rules)
    // No client-side access needed

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
