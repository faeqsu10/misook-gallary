rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Artworks: public read, authenticated write
    match /artworks/{artworkId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    // Inquiries: anyone can create (contact form) with field validation, only authenticated can read/delete
    match /inquiries/{inquiryId} {
      allow create: if request.resource.data.keys().hasOnly(['name', 'email', 'type', 'artwork', 'message', 'createdAt'])
        && request.resource.data.name is string
        && request.resource.data.name.size() < 200
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.message.size() < 5000;
      allow read, update, delete: if request.auth != null;
    }

    // Enhancement logs: authenticated read/write
    match /enhance_logs/{logId} {
      allow read, write: if request.auth != null;
    }

    // Guestbook: submissions via server API only, admin can read/update/delete
    match /guestbook/{entryId} {
      allow read, update, delete: if request.auth != null;
    }

    // Deny everything else by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
